                    "mode": "raw",
                    "raw": "{\n    \"name\": \"karno\",\n    \"email\": \"karnohatta@gmail.com\",\n    \"password\": \"123457\",\n    \"password_confirmation\": \"123457\"\n}",
                    "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "http://127.0.0.1:8000/api/v1/register", "protocol": "http", "host": ["127", "0", "0", "1"], "port": "8000", "path": ["api", "v1", "register"] }
